# 复制为 deploy/.env 后再填写真实值。
# deploy/.env 会被 .gitignore 忽略，不要提交真实密码或密钥。

POSTGRES_DB=panto
POSTGRES_USER=panto
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password

# JWT 密钥必须使用足够长的随机字符串。生产环境不要复用下面的示例值。
PANTO_JWT_ACCESS_TOKEN_SECRET=replace-with-a-long-random-access-token-secret-at-least-32-bytes
PANTO_JWT_REFRESH_TOKEN_SECRET=replace-with-a-long-random-refresh-token-secret-at-least-32-bytes
PANTO_JWT_REFRESH_COOKIE_SECURE=true

# 本地生产模拟默认使用 local tag；CI/CD 后可以改成 Git SHA 或版本号。
PANTO_IMAGE_TAG=local

# 前端生产镜像默认同源访问 /api/v1，由 gateway Nginx 转发到后端。
VITE_API_BASE_URL=/api/v1

# 小型 EC2 的保守 JVM 内存参数，可按实例规格调整。
JAVA_OPTS=-Xms256m -Xmx512m
